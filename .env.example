# MAZU 沙特多灾种预警智能体 — 环境变量配置
# 复制此文件为 .env 并填入实际值

# DeepSeek API Key（必填）
DEEPSEEK_API_KEY=your-api-key-here

# 数据目录（可选，默认 ./indicators）
# MAZU_INDICATORS_DIR=/path/to/indicators

# 模型名称（可选，默认 deepseek-v4-flash）
# MAZU_LLM_MODEL=deepseek-v4-flash

# API 地址（可选，默认 https://api.deepseek.com）
# MAZU_LLM_BASE_URL=https://api.deepseek.com