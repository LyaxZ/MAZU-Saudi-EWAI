# MAZU 沙特多灾种预警智能体 — 环境变量配置
# 复制此文件为 .env 并填入实际值

# ---------- LLM API（必填，三项都必须设置） ----------
# 支持 OpenAI 兼容接口：DeepSeek / OpenAI / 本地模型等
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# ---------- 数据目录（可选） ----------
# MAZU_INDICATORS_DIR=/path/to/indicators