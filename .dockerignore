# Docker 构建忽略文件
# 减小构建上下文，加速 docker build

# === Git ===
.git/
.gitignore
.gitattributes

# === Python ===
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.eggs/
dist/
build/
*.egg

# === 虚拟环境 ===
venv/
.venv/
env/
.env
.env.local

# === IDE ===
.idea/
.vscode/
*.swp
*.swo
*~

# === Jupyter ===
.ipynb_checkpoints/
*.ipynb
notebooks/

# === 项目文档（不参与运行） ===
AGENTS.md
ALIGNMENT.md
DEFENSE_SCRIPT.md
PROJECT_STRUCTURE.md
TASK_DIVISION.md
mazu_saudi_project_plan.md
saudi_extreme_event_indicator_report.md
CLAUDE.md

# === 运行时产物（会通过 volume 挂载或运行时生成） ===
outputs/logs/
outputs/*.png
outputs/*.html
outputs/*.parquet

# === 测试 ===
tests/

# === 数据 / 模型（通过 volume 挂载） ===
indicators/
